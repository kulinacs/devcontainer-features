{
  "id": "claude-code",
  "version": "1.1.0",
  "name": "Claude Code",
  "documentationURL": "https://github.com/kulinacs/devcontainer-features/tree/main/src/claude-code",
  "description": "Installs the Claude Code CLI and Claude Code for VS Code",
  "options": {
    "version": {
      "type": "string",
      "proposals": ["stable", "latest"],
      "default": "stable",
      "description": "The release version/channel to install."
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["anthropic.claude-code"],
      "settings": {
        "github.copilot.chat.codeGeneration.instructions": [
          {
            "text": "This dev container includes Claude Code (`claude`) pre-installed and available on the `PATH`."
          }
        ]
      }
    }
  }
}
